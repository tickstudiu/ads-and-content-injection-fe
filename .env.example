# ════════════════════════════════════════════════════════════
#  com7-ads-inject-widget — Environment Variables
#  Copy เป็น .env แล้วแก้ค่าตาม environment ของตัวเอง
#  ไฟล์ .env ถูก gitignore แล้ว — ห้าม commit ค่าจริง
# ════════════════════════════════════════════════════════════

# ── Widget / API ─────────────────────────────────────────────
# Base URL ของ Backend Ads API (ไม่มี trailing slash)
VITE_ADS_BASE_URL=https://api.com7.th

# ── Playground Testing ────────────────────────────────────────
# Base URL ที่ widget ใน playground จะยิงไป
# ใช้ https://api-mock.local เพื่อให้ XHR interceptor รับแทน (mock mode)
# เปลี่ยนเป็น URL จริงถ้าต้องการ integration test กับ backend จริง
VITE_PLAYGROUND_BASE_URL=https://api-mock.local

# Client ID ที่ใช้ใน playground
VITE_PLAYGROUND_CLIENT_ID=demo-client

# GTM Container ID สำหรับ playground (ดู GTM console)
VITE_GTM_CONTAINER_ID=GTM-XXXXXXX

# Consent default ใน playground: denied | granted
# denied = ต้องกด Accept ก่อน tracking จะทำงาน
# granted = bypass consent banner (ใช้ตอน dev เพื่อ test tracking โดยตรง)
VITE_PLAYGROUND_CONSENT_DEFAULT=denied

# CDN prefix สำหรับรูป ad ใน mock data
VITE_ADS_IMAGE_CDN=https://placehold.co

# ── Feature Flags ─────────────────────────────────────────────
# true  = ใช้ XHR interceptor แทน API จริง (ไม่ต้องมี backend)
# false = ยิง API จริงตาม VITE_PLAYGROUND_BASE_URL
VITE_PLAYGROUND_USE_MOCK_API=true
